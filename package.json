{
  "name": "inkai",
  "version": "0.4.0",
  "description": "AI-Powered Book Writing Agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "inkai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:web": "cd web && npm install && npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "book",
    "writing",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "@inquirer/prompts": "^7.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "figlet": "^1.8.0",
    "jszip": "^3.10.1",
    "lowdb": "^7.0.1",
    "nanoid": "^5.0.9",
    "openai": "^4.73.0",
    "ora": "^8.1.1",
    "simple-git": "^3.27.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
